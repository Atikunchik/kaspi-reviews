# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=kaspi_reviews
MONGODB_COLLECTION_NAME=reviews
MONGODB_PRODUCT_IDS_COLLECTION_NAME=product_ids

# Kaspi scraping
KASPI_COOKIE=
KASPI_MERCHANT_IDS=

# Logging — leave empty to log to console only (systemd/gunicorn captures it)
# Set to a directory path to also write a rotating app.log file
LOG_DIR=/var/log/kaspi-reviews
